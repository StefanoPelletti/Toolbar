<Window x:Class="Toolbar.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300" Height="382"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="{StaticResource DialogBackground}"
            BorderBrush="{StaticResource BarBorder}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="OnTitleBar_Drag"
                    Background="Transparent">
                <Grid Margin="12,0,4,0">
                    <TextBlock Text="Settings"
                               Foreground="{StaticResource ForegroundPrimary}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            Width="28" Height="28"
                            Content="&#xE8BB;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="11"
                            Click="OnClose"
                            Style="{StaticResource CloseButton}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="16,10,16,12">
                <CheckBox x:Name="AlwaysOnTopBox"
                          Content="Always on top"
                          Foreground="{StaticResource ForegroundPrimary}"
                          Margin="0,0,0,8"/>
                <CheckBox x:Name="LaunchAtBootBox"
                          Content="Launch at Windows startup"
                          Foreground="{StaticResource ForegroundPrimary}"
                          Margin="0,0,0,8"/>
                <CheckBox x:Name="VerticalBox"
                          Content="Vertical layout"
                          Foreground="{StaticResource ForegroundPrimary}"
                          Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0"
                              x:Name="HotkeyBox"
                              Content="Global show/hide hotkey"
                              Foreground="{StaticResource ForegroundPrimary}"
                              VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            x:Name="HotkeyButton"
                            MinWidth="110"
                            Padding="8,3"
                            Click="OnRebindHotkey"
                            ToolTip="Click, then press the key combination"
                            Background="Transparent"
                            Foreground="{StaticResource ForegroundPrimary}"
                            BorderBrush="{StaticResource BarBorder}"
                            BorderThickness="1"/>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Interface scale"
                               Foreground="{StaticResource ForegroundPrimary}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               x:Name="ScaleLabel"
                               Foreground="{StaticResource ForegroundPrimary}"
                               VerticalAlignment="Center"/>
                </Grid>
                <Slider x:Name="ScaleSlider"
                        Minimum="0" Maximum="5"
                        TickFrequency="1"
                        TickPlacement="BottomRight"
                        IsSnapToTickEnabled="True"
                        SmallChange="1" LargeChange="1"
                        Margin="0,0,0,14"
                        ValueChanged="OnScaleChanged"/>

                <Button Content="Save"
                        Width="72"
                        HorizontalAlignment="Right"
                        Padding="0,5"
                        Click="OnSave"
                        Background="#0E70C0"
                        Foreground="White"
                        BorderThickness="0"/>

                <Border Height="1"
                        Background="{StaticResource BarBorder}"
                        Opacity="0.5"
                        Margin="0,14,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="VersionLabel"
                               Foreground="{StaticResource ForegroundPrimary}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            x:Name="UpdateButton"
                            Content="Check for updates"
                            MinWidth="140"
                            Padding="8,5"
                            Click="OnUpdateClick"
                            Background="Transparent"
                            Foreground="{StaticResource ForegroundPrimary}"
                            BorderBrush="{StaticResource BarBorder}"
                            BorderThickness="1"/>
                </Grid>

                <ProgressBar x:Name="UpdateProgress"
                             Height="4"
                             Minimum="0" Maximum="1"
                             Margin="0,8,0,0"
                             Visibility="Collapsed"/>

                <TextBlock x:Name="UpdateStatus"
                           Foreground="{StaticResource ForegroundPrimary}"
                           Opacity="0.7"
                           FontSize="11"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

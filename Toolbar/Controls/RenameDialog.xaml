<Window x:Class="Toolbar.Controls.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300" Height="130"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="{StaticResource DialogBackground}"
            BorderBrush="{StaticResource BarBorder}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="OnTitleBar_Drag"
                    Background="Transparent">
                <Grid Margin="12,0,4,0">
                    <TextBlock Text="Rename shortcut"
                               Foreground="{StaticResource ForegroundPrimary}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            Width="28" Height="28"
                            Content="&#xE8BB;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="11"
                            Click="OnCancel"
                            Style="{StaticResource CloseButton}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="12,8,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="NameBox"
                         Grid.Row="0"
                         Background="{StaticResource BarBorder}"
                         Foreground="{StaticResource ForegroundPrimary}"
                         CaretBrush="{StaticResource ForegroundPrimary}"
                         BorderBrush="#555555"
                         BorderThickness="1"
                         Padding="8,5"
                         FontSize="13"
                         KeyDown="OnKeyDown"
                         VerticalAlignment="Center"/>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn"
                            Content="Cancel"
                            Width="72"
                            Margin="0,0,8,0"
                            Padding="0,5"
                            Click="OnCancel"
                            Background="{StaticResource BarBorder}"
                            Foreground="{StaticResource ForegroundPrimary}"
                            BorderBrush="#555555"
                            BorderThickness="1"/>
                    <Button x:Name="OkBtn"
                            Content="OK"
                            Width="72"
                            Padding="0,5"
                            IsDefault="True"
                            Click="OnOk"
                            Background="#0E70C0"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

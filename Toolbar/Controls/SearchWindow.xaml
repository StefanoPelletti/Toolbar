<Window x:Class="Toolbar.Controls.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="280"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Border Background="{StaticResource BarBackground}"
            BorderBrush="{StaticResource BarBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="6">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel>
            <TextBox x:Name="SearchBox"
                     Background="{StaticResource TileHover}"
                     Foreground="{StaticResource ForegroundPrimary}"
                     CaretBrush="{StaticResource ForegroundPrimary}"
                     BorderThickness="0"
                     Padding="8,6"
                     FontSize="14"
                     TextChanged="OnSearchTextChanged"/>
            <ListBox x:Name="SearchList"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{StaticResource ForegroundPrimary}"
                     MaxHeight="300"
                     Margin="0,6,0,0"
                     MouseDoubleClick="OnListDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="6,5"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource TilePressed}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource TileHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,8,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding DisplayName}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource ForegroundPrimary}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Border>
</Window>

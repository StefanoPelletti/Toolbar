<Window x:Class="Toolbar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Toolbar"
        Height="56"
        SizeToContent="Width"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        AllowDrop="True"
        Drop="OnWindow_Drop"
        DragOver="OnWindow_DragOver">

    <Border Background="{StaticResource BarBackground}"
            BorderBrush="{StaticResource BarBorder}"
            BorderThickness="1"
            CornerRadius="8"
            MouseLeftButtonDown="OnDragArea_MouseLeftButtonDown">

        <!-- OuterPanel flips Orientation for vertical mode -->
        <StackPanel x:Name="OuterPanel" Orientation="Horizontal">

            <!-- Shortcut tiles zone -->
            <StackPanel x:Name="ShortcutsHost"
                        Orientation="Horizontal"
                        Margin="6,4,4,4">

                <!-- Add (+) tile — always last child of ShortcutsHost -->
                <Border x:Name="AddTile"
                        Width="44" Height="44"
                        Background="Transparent"
                        BorderBrush="{StaticResource BarBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="2,0,2,0"
                        Cursor="Hand"
                        MouseLeftButtonDown="OnAddTile_Click"
                        ToolTip="Left-click: add app/shortcut  •  Right-click: add folder">
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Add Application / Shortcut…" Click="OnAddFile_Click"/>
                            <MenuItem Header="Add Folder…" Click="OnAddFolder_Click"/>
                        </ContextMenu>
                    </Border.ContextMenu>
                    <TextBlock Text="+"
                               Foreground="{StaticResource ForegroundDim}"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Chrome buttons zone — order and orientation flipped in vertical mode -->
            <StackPanel x:Name="ButtonsHost"
                        Orientation="Horizontal"
                        Margin="4,4,6,4">
                <Button x:Name="SettingsBtn"
                        Style="{StaticResource ChromeButton}"
                        Content="&#xE713;"
                        ToolTip="Settings"
                        Click="OnSettings_Click"/>
                <Button x:Name="MinBtn"
                        Style="{StaticResource ChromeButton}"
                        Content="&#xE921;"
                        ToolTip="Minimize to tray"
                        Click="OnMinimize_Click"/>
                <Button x:Name="CloseBtn"
                        Style="{StaticResource CloseButton}"
                        Content="&#xE8BB;"
                        ToolTip="Close"
                        Click="OnClose_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>

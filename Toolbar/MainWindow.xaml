<Window x:Class="Toolbar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Toolbar"
        Height="56"
        SizeToContent="Width"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        AllowDrop="True"
        Drop="OnWindow_Drop"
        DragOver="OnWindow_DragOver">

    <Border x:Name="RootBorder"
            Background="{StaticResource BarBackground}"
            BorderBrush="{StaticResource BarBorder}"
            BorderThickness="1"
            CornerRadius="8"
            MouseLeftButtonDown="OnDragArea_MouseLeftButtonDown">

        <Grid>
            <!-- OuterPanel flips Orientation for vertical mode -->
            <StackPanel x:Name="OuterPanel" Orientation="Horizontal">

                <!-- Shortcut tiles zone — WrapPanel so tiles flow into columns/rows -->
                <WrapPanel x:Name="ShortcutsHost"
                           Orientation="Horizontal"
                           Margin="6,4,4,4"/>

                <!-- Single ⋮ menu button -->
                <StackPanel x:Name="ButtonsHost"
                            Orientation="Horizontal"
                            Margin="4,4,6,4">
                    <Button x:Name="MenuBtn"
                            Style="{StaticResource ChromeButton}"
                            Content="&#xE712;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="16"
                            ToolTip="Menu"
                            Click="OnMenu_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="MainMenu" Placement="Bottom">
                                <MenuItem Header="Search…" Click="OnSearch_Click"/>
                                <Separator/>
                                <MenuItem Header="Add Application / Shortcut…" Click="OnAddFile_Click"/>
                                <MenuItem Header="Add Folder…"                  Click="OnAddFolder_Click"/>
                                <Separator/>
                                <MenuItem Header="Settings"                     Click="OnSettings_Click"/>
                                <Separator/>
                                <MenuItem Header="Minimize to Tray"             Click="OnMinimize_Click"/>
                                <MenuItem Header="Close"                        Click="OnClose_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

            </StackPanel>

            <!-- Resize grip — repositioned in code for vertical vs horizontal mode -->
            <Border x:Name="ResizeGrip"
                    Width="8"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    Cursor="SizeWE"
                    MouseLeftButtonDown="OnGrip_Down"
                    MouseMove="OnGrip_Move"
                    MouseLeftButtonUp="OnGrip_Up">
                <StackPanel x:Name="GripDots"
                            Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Ellipse Width="3" Height="3" Fill="{StaticResource ForegroundDim}" Margin="0,2"/>
                    <Ellipse Width="3" Height="3" Fill="{StaticResource ForegroundDim}" Margin="0,2"/>
                    <Ellipse Width="3" Height="3" Fill="{StaticResource ForegroundDim}" Margin="0,2"/>
                </StackPanel>
            </Border>

            <!-- Quick-launch palette: opened by the global hotkey or the menu.
                 Type to filter, ↑/↓ to select, Enter to launch. -->
            <Popup x:Name="SearchPopup"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   Closed="OnSearchClosed">
                <Border Background="{StaticResource BarBackground}"
                        BorderBrush="{StaticResource BarBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Width="264"
                        Margin="8"
                        Padding="6">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="2" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBox x:Name="SearchBox"
                                 Background="{StaticResource TileHover}"
                                 Foreground="{StaticResource ForegroundPrimary}"
                                 CaretBrush="{StaticResource ForegroundPrimary}"
                                 BorderThickness="0"
                                 Padding="8,6"
                                 FontSize="14"
                                 TextChanged="OnSearchTextChanged"
                                 PreviewKeyDown="OnSearchKeyDown"/>
                        <ListBox x:Name="SearchList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource ForegroundPrimary}"
                                 MaxHeight="300"
                                 Margin="0,6,0,0"
                                 MouseDoubleClick="OnSearchListDoubleClick"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,5"/>
                                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource TilePressed}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource TileHover}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Icon}" Width="20" Height="20" Margin="0,0,8,0"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource ForegroundPrimary}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

    </Border>
</Window>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>

    <!-- Application icon: sets the EXE icon, and the system tray picks it up
         via ExtractAssociatedIcon(ProcessPath) in App.xaml.cs. -->
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>

    <!-- Identity -->
    <Product>Toolbar</Product>
    <Company>Stefano Pelletti</Company>
    <Description>A minimal floating launcher toolbar for Windows</Description>
    <Copyright>© 2026 Stefano Pelletti</Copyright>
    <Version>1.3.2</Version>
    <AssemblyVersion>1.3.2.0</AssemblyVersion>
    <FileVersion>1.3.2.0</FileVersion>
  </PropertyGroup>

  <!-- Portable single-file release profile -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <TrimmerRootDescriptor/>
  </PropertyGroup>

</Project>
